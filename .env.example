# Supabase 配置
# 请替换为你自己的 Supabase 项目凭证
# 获取方式：登录 Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 使用说明：
# 1. 访问 https://supabase.com 创建账号和项目
# 2. 在项目设置中复制 Project URL 和 anon public key
# 3. 替换上面的占位符
# 4. 保存此文件后重启开发服务器
